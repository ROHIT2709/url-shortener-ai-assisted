# Copy this file to .env and adjust the values.
# .env is git-ignored and docker-ignored — never commit real credentials.

POSTGRES_DB=urlshortener
POSTGRES_USER=urlshortener
POSTGRES_PASSWORD=changeme
POSTGRES_PORT=5432

APP_PORT=8080
APP_BASE_URL=http://localhost:8080
APP_DEFAULT_EXPIRY_DAYS=30

# Hibernate schema mode: use `update` for dev; prefer `validate` + migrations in prod
DDL_AUTO=update
